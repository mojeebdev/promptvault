# .env.local.example
# Copy to .env.local and fill real values. Never commit real secrets.

# Tatum — get free key at https://dashboard.tatum.io
TATUM_API_KEY=your_tatum_api_key_here

# Tatum Sui RPC — MAINNET ONLY (project requirement)
NEXT_PUBLIC_SUI_MAINNET_RPC=https://sui-mainnet.gateway.tatum.io

# OpenRouter — get free key at https://openrouter.ai (use Gemini 2.5 Flash Lite free)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Walrus MAINNET (public)
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus.space

# App
NEXT_PUBLIC_APP_URL=https://promptvault.mojeeb.xyz

# Optional: for demo on-chain publish from server (MAINNET private key — real SUI/gas)
# DEMO_SUI_PRIVATE_KEY=0x...
# For client-side demo you can also paste a mainnet key directly in the UI (ephemeral, use with extreme caution)
